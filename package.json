{
  "name": "@carllee1983/doc2api",
  "version": "1.1.0",
  "description": "Convert API documentation (PDF, HTML) to OpenAPI 3.x specs — AI Agent collaboration tool",
  "type": "module",
  "bin": {
    "doc2api": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/lib.js",
    "./cli": "./dist/index.js"
  },
  "files": ["dist/", "bridge/", "LICENSE", "README.md"],
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "build": "bun build src/index.ts src/lib.ts --outdir dist --target bun --format esm",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": ["pdf", "html", "openapi", "api-docs", "cli", "ai-agent"],
  "author": "Carl Lee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthropics/doc2api.git"
  },
  "bugs": {
    "url": "https://github.com/anthropics/doc2api/issues"
  },
  "homepage": "https://github.com/anthropics/doc2api#readme",
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "typescript": "^5.7.0",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@readme/openapi-parser": "^6.0.0",
    "cheerio": "^1.2.0",
    "unpdf": "^1.4.0"
  }
}
